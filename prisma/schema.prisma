generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum Platform {
  YOUTUBE
  INSTAGRAM
  TIKTOK
  FACEBOOK
}

enum VideoStatus {
  UPLOADED
  PROCESSING
  READY
  FAILED
}

enum PublishStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  CANCELED
}

enum PlanTier {
  FREE
  PRO
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String
  passwordHash   String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  socialAccounts SocialAccount[]
  videos         Video[]
  drafts         Draft[]
  subscription   Subscription?
  usageCounters  UsageCounter[]
}

model SocialAccount {
  id           String       @id @default(cuid())
  platform     Platform
  handle       String
  externalId   String?
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  publishJobs  PublishJob[]

  @@index([userId])
  @@unique([platform, externalId])
}

model Video {
  id           String       @id @default(cuid())
  title        String
  description  String?
  sourceUrl    String
  localPath    String?
  thumbnailUrl String?
  durationSec  Int?
  status       VideoStatus  @default(UPLOADED)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  publishJobs  PublishJob[]
  drafts       Draft[]

  @@index([userId])
}

model Draft {
  id           String    @id @default(cuid())
  caption      String
  platform     Platform
  hashtags     String[]
  scheduledFor DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  userId       String
  videoId      String?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  video        Video?    @relation(fields: [videoId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([platform, createdAt])
}

model PublishJob {
  id              String        @id @default(cuid())
  status          PublishStatus @default(PENDING)
  scheduledFor    DateTime
  publishedAt     DateTime?
  remotePostId    String?
  remotePostUrl   String?
  errorMessage    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  videoId         String
  socialAccountId String
  video           Video         @relation(fields: [videoId], references: [id], onDelete: Cascade)
  socialAccount   SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)

  @@index([videoId])
  @@index([socialAccountId])
  @@index([status, scheduledFor])
}

model Subscription {
  id                     String             @id @default(cuid())
  userId                 String             @unique
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                   PlanTier           @default(FREE)
  status                 SubscriptionStatus @default(ACTIVE)
  provider               String             @default("mock")
  providerCustomerId     String?
  providerSubscriptionId String?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean            @default(false)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  @@index([plan, status])
}

model UsageCounter {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  metric      String
  periodStart DateTime
  count       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, metric, periodStart])
  @@index([userId, metric])
}

model StripeEvent {
  id        String   @id
  type      String
  processed Boolean  @default(false)
  createdAt DateTime @default(now())
}
